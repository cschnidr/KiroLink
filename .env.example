# Telegram
# Bot token from @BotFather (Telegram): /newbot → pick a name → token looks like "123456:ABC-DEF..."
KIROLINK_BOT_TOKEN=your-bot-token-here
# Your numeric Telegram user ID(s), comma-separated. Get yours from @userinfobot on Telegram.
KIROLINK_ALLOWED_USERS=123456789

# Kiro CLI (headless mode)
KIROLINK_KIRO_COMMAND=/var/lib/kirolink/.local/bin/kiro-cli
# ── Tool trust (pick ONE) ───────────────────────────────────────
# IMPORTANT: if KIROLINK_KIRO_EXTRA_ARGS is removed/unset, the code falls
# back to --trust-all-tools. Always keep one of the presets below set
# explicitly so you know what tools Kiro is allowed to run.
#
# Valid built-in Kiro CLI tool names observed in practice:
#   read, grep, glob, code, shell, write, aws, report
# (Run `kiro-cli chat --help` on your install to confirm.)
#
# ── Practical note ──────────────────────────────────────────────
# `read` lets Kiro read files but NOT tail logs, list directories, run
# `systemctl status`, or similar — those need `shell`. If you picked this
# profile expecting "read-only troubleshooting" and Kiro keeps saying it
# can't help, you likely want the "read + shell" profile below.
#
# Safe: read + search (no shell, no writes). Good for code exploration.
KIROLINK_KIRO_EXTRA_ARGS=--trust-tools=read,grep,glob,code
#
# Troubleshooting (RECOMMENDED for a home server / openHAB / systemd):
# Adds `shell` so Kiro can run `tail`, `ls`, `cat`, `head`, `journalctl`,
# `systemctl status`, etc. Still no file writes. The shell tool can run
# destructive commands like `rm` — your systemd sandbox (ProtectSystem,
# ReadWritePaths) is the real containment boundary.
# KIROLINK_KIRO_EXTRA_ARGS=--trust-tools=read,grep,glob,code,shell
#
# Full non-AWS access (read + shell + write). Lets Kiro actually fix
# problems — edit config files, restart services.
# KIROLINK_KIRO_EXTRA_ARGS=--trust-tools=read,grep,glob,code,shell,write
#
# Trust all: every tool auto-approved including aws/report. See README.
# KIROLINK_KIRO_EXTRA_ARGS=--trust-all-tools
#
# Custom agent: use your own kiro-cli agent for tailored per-command trust.
# KIROLINK_KIRO_EXTRA_ARGS=--agent ~/.kiro/agents/my-agent

# Default working dir for Kiro (service user's home on a systemd install).
# Note: `~` is NOT expanded — use absolute paths.
KIROLINK_KIRO_CWD=/var/lib/kirolink

# Restrict /cd to these root directories (comma-separated).
# Leave unset to allow any directory.
KIROLINK_ALLOWED_CWDS=/var/lib/kirolink,/tmp

KIROLINK_KIRO_TIMEOUT_MS=300000

# PIN unlock window in minutes (0 disables re-lock). Only relevant when
# KIROLINK_BOT_PIN is set — determines how long an /unlock stays valid.
KIROLINK_IDLE_TIMEOUT_MINUTES=30

# Optional: use an explicit Kiro API key instead of the inherited login
# KIRO_API_KEY=

# Conversation history (prepended as context to each headless call)
KIROLINK_CONVERSATION_PATH=/var/lib/kirolink/.local/share/kirolink/conversation.log
KIROLINK_CONVERSATION_MAX_TURNS=10

# Telegram reply behavior
KIROLINK_FILE_UPLOAD_THRESHOLD=10000

# Security
# PIN required on first message after idle/boot. CHANGE THIS before deploying.
# Example value 5476 = "KIRO" on a phone keypad (K=5, I=4, R=7, O=6).
KIROLINK_BOT_PIN=5476
KIROLINK_RATE_LIMIT_PER_MIN=10
KIROLINK_AUDIT_LOG_PATH=/var/lib/kirolink/.local/share/kirolink/audit.log
